APP_NAME=AI-PMS Collection API
DATABASE_URL=postgresql://ai_pms:ai_pms@localhost:5432/ai_pms
DEFAULT_LEASE_SECONDS=300
MAX_JOB_ATTEMPTS=3
AUDIO_STORAGE_DIR=storage/audio
PLATFORM_API_URL=http://localhost:8000
PLATFORM_CALLBACK_ENABLED=true
PLATFORM_CALLBACK_TIMEOUT_SECONDS=10
PLATFORM_CALLBACK_SECRET_ID=dev-v1
PLATFORM_CALLBACK_SECRET=dev-collection-callback-secret
PLATFORM_CALLBACK_MAX_ATTEMPTS=5
PLATFORM_CALLBACK_BASE_BACKOFF_SECONDS=30
PLATFORM_CALLBACK_MAX_BACKOFF_SECONDS=1800
PLATFORM_CALLBACK_RETRY_LOOP_ENABLED=true
PLATFORM_CALLBACK_RETRY_INTERVAL_SECONDS=30
PLATFORM_CALLBACK_RETRY_BATCH_SIZE=20
