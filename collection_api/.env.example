APP_NAME=AI-PMS Collection & Analysis Service
DATABASE_URL=postgresql://ai_pms:ai_pms@localhost:5432/ai_pms
AIPMS_COLLECTION_BIND_HOST=127.0.0.1
AIPMS_COLLECTION_PORT=8200
AIPMS_COLLECTION_ALLOW_PUBLIC_BIND=0
DEFAULT_LEASE_SECONDS=300
MAX_JOB_ATTEMPTS=3
AUDIO_STORAGE_DIR=storage/audio
PLATFORM_API_URL=http://localhost:8000
PLATFORM_CALLBACK_ENABLED=true
PLATFORM_CALLBACK_TIMEOUT_SECONDS=10
# ⚠️ 외부 네트워크 노출 시 반드시 변경 (scripts/generate_prod_secrets.sh 사용)
PLATFORM_CALLBACK_SECRET_ID=dev-v1
PLATFORM_CALLBACK_SECRET=dev-collection-callback-secret
PLATFORM_CALLBACK_MAX_ATTEMPTS=5
PLATFORM_CALLBACK_BASE_BACKOFF_SECONDS=30
PLATFORM_CALLBACK_MAX_BACKOFF_SECONDS=1800
PLATFORM_CALLBACK_RETRY_LOOP_ENABLED=true
PLATFORM_CALLBACK_RETRY_INTERVAL_SECONDS=30
PLATFORM_CALLBACK_RETRY_BATCH_SIZE=20

# ── 내부 분석 워커 ────────────────────────────────────────────────────────────
WORKER_ID=integrated-worker-001
WORKER_LOOP_ENABLED=true
WORKER_LOOP_INTERVAL_SECONDS=10

# ── Ollama LLM ────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:4b
OLLAMA_FALLBACK_MODELS=qwen2.5:3b,qwen2.5:7b,qwen2:7b
DEFAULT_CONTEXT_LIMIT=8192
OLLAMA_TIMEOUT_SECONDS=180

# ── Whisper STT ───────────────────────────────────────────────────────────────
# Mac mini: /opt/homebrew/bin/whisper-cli
# Windows:  C:\path\to\whisper-cli.exe
WHISPER_CPP_BIN=/opt/homebrew/bin/whisper-cli
FFMPEG_BIN=/opt/homebrew/bin/ffmpeg
# 비어 있으면 자동으로 models/whisper/ggml-small.bin 사용
WHISPER_MODEL_PATH=
WHISPER_TIMEOUT_SECONDS=300
