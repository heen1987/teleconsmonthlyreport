# ── 서버 바인딩 ──────────────────────────────────────────────────────
AIPMS_ANALYSIS_BIND_HOST=127.0.0.1
AIPMS_ANALYSIS_PORT=8200
# 외부 LAN/인터넷 노출 시 1로 변경 (보안 위험 인지 후 사용)
AIPMS_ANALYSIS_ALLOW_PUBLIC_BIND=0

# ── DB (Platform API 와 동일한 PostgreSQL) ────────────────────────────
DATABASE_URL=postgresql://aipms:aipms@localhost:5432/aipms

# ── Platform API 콜백 ─────────────────────────────────────────────────
PLATFORM_API_URL=http://localhost:8000
# ⚠️ 반드시 generate_prod_secrets.sh 로 교체하세요
PLATFORM_CALLBACK_SECRET=dev-platform-callback-secret
PLATFORM_CALLBACK_SECRET_ID=default
PLATFORM_CALLBACK_ENABLED=true
PLATFORM_CALLBACK_TIMEOUT_SECONDS=30
PLATFORM_CALLBACK_MAX_ATTEMPTS=5

# ── Ollama LLM ────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:4b
OLLAMA_FALLBACK_MODELS=qwen2.5:3b,qwen2.5:7b,qwen2:7b
DEFAULT_CONTEXT_LIMIT=8192
OLLAMA_TIMEOUT_SECONDS=180

# ── Whisper STT ───────────────────────────────────────────────────────
WHISPER_CPP_BIN=/opt/homebrew/bin/whisper-cli
FFMPEG_BIN=/opt/homebrew/bin/ffmpeg
WHISPER_MODEL_PATH=models/whisper/ggml-small.bin
WHISPER_TIMEOUT_SECONDS=300

# ── 오디오 파일 저장 경로 (상대경로 또는 절대경로) ────────────────────
AUDIO_STORAGE_DIR=audio_storage

# ── 내부 워커 ─────────────────────────────────────────────────────────
WORKER_ID=integrated-worker-001
WORKER_LOOP_ENABLED=true
WORKER_LOOP_INTERVAL_SECONDS=10
DEFAULT_LEASE_SECONDS=600
MAX_JOB_ATTEMPTS=3
